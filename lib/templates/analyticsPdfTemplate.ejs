<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EvoFit Progress Report</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap');

    :root {
      --primary: #2563EB;
      --primary-dark: #1D4ED8;
      --primary-light: #DBEAFE;
      --accent: #F97316;
      --accent-light: #FFF7ED;
      --success: #10B981;
      --success-light: #D1FAE5;
      --warning: #F59E0B;
      --warning-light: #FEF3C7;
      --danger: #EF4444;
      --danger-light: #FEE2E2;
      --gray-50: #F9FAFB;
      --gray-100: #F3F4F6;
      --gray-200: #E5E7EB;
      --gray-300: #D1D5DB;
      --gray-400: #9CA3AF;
      --gray-500: #6B7280;
      --gray-600: #4B5563;
      --gray-700: #374151;
      --gray-800: #1F2937;
      --gray-900: #111827;
      --font-heading: 'Outfit', sans-serif;
      --font-body: 'Inter', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font-body);
      color: var(--gray-800);
      line-height: 1.6;
      font-size: 11pt;
      background: white;
    }

    .page {
      width: 210mm;
      min-height: 297mm;
      padding: 20mm 18mm;
      page-break-after: always;
      position: relative;
    }

    .page:last-child { page-break-after: auto; }

    /* Cover Page */
    .cover-page {
      background: linear-gradient(135deg, #1E293B 0%, #0F172A 50%, #1E1B4B 100%);
      color: white;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 40mm 30mm;
    }

    .cover-logo {
      width: 80px;
      height: 80px;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 24px;
      font-family: var(--font-heading);
      font-size: 32px;
      font-weight: 800;
      color: white;
      letter-spacing: -1px;
    }

    .cover-title {
      font-family: var(--font-heading);
      font-size: 36pt;
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 8px;
      background: linear-gradient(to right, #60A5FA, #A78BFA);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .cover-subtitle {
      font-size: 14pt;
      font-weight: 300;
      color: #94A3B8;
      margin-bottom: 48px;
    }

    .cover-details {
      display: flex;
      flex-direction: column;
      gap: 12px;
      font-size: 11pt;
    }

    .cover-detail {
      display: flex;
      align-items: center;
      gap: 8px;
      color: #CBD5E1;
    }

    .cover-detail-label {
      color: #64748B;
      min-width: 80px;
      text-align: right;
    }

    .cover-detail-value {
      font-weight: 600;
      color: white;
    }

    .cover-divider {
      width: 60px;
      height: 3px;
      background: linear-gradient(to right, var(--primary), var(--accent));
      border-radius: 2px;
      margin: 32px auto;
    }

    .cover-footer {
      margin-top: auto;
      padding-top: 40px;
      font-size: 9pt;
      color: #475569;
    }

    /* Section Headers */
    .section-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 2px solid var(--gray-100);
    }

    .section-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
    }

    .section-title {
      font-family: var(--font-heading);
      font-size: 18pt;
      font-weight: 700;
      color: var(--gray-900);
    }

    .section-subtitle {
      font-size: 9pt;
      color: var(--gray-400);
      margin-top: 2px;
    }

    /* Stat Cards */
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-bottom: 24px;
    }

    .stat-card {
      background: var(--gray-50);
      border: 1px solid var(--gray-200);
      border-radius: 12px;
      padding: 16px;
      text-align: center;
    }

    .stat-value {
      font-family: var(--font-heading);
      font-size: 24pt;
      font-weight: 700;
      line-height: 1;
      margin-bottom: 4px;
    }

    .stat-label {
      font-size: 8pt;
      color: var(--gray-500);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 500;
    }

    .stat-blue .stat-value { color: var(--primary); }
    .stat-green .stat-value { color: var(--success); }
    .stat-orange .stat-value { color: var(--accent); }
    .stat-purple .stat-value { color: #7C3AED; }

    /* Measurement Table */
    .measurement-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 24px;
    }

    .measurement-table th {
      background: var(--gray-50);
      padding: 10px 12px;
      text-align: left;
      font-size: 8pt;
      font-weight: 600;
      color: var(--gray-500);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 2px solid var(--gray-200);
    }

    .measurement-table td {
      padding: 10px 12px;
      border-bottom: 1px solid var(--gray-100);
      font-size: 10pt;
    }

    .delta-up { color: var(--success); font-weight: 600; }
    .delta-down { color: var(--danger); font-weight: 600; }
    .delta-unchanged { color: var(--gray-400); }

    /* Delta Summary Cards */
    .delta-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-bottom: 20px;
    }

    .delta-card {
      border-radius: 12px;
      padding: 16px;
      text-align: center;
    }

    .delta-card-up { background: var(--success-light); border: 1px solid #A7F3D0; }
    .delta-card-down { background: var(--danger-light); border: 1px solid #FECACA; }
    .delta-card-unchanged { background: var(--gray-50); border: 1px solid var(--gray-200); }

    .delta-card-value {
      font-family: var(--font-heading);
      font-size: 20pt;
      font-weight: 700;
      line-height: 1;
      margin-bottom: 4px;
    }

    .delta-card-label {
      font-size: 8pt;
      color: var(--gray-500);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* CSS Bar Charts */
    .bar-chart {
      display: flex;
      align-items: flex-end;
      gap: 8px;
      height: 160px;
      padding: 0 4px;
      border-bottom: 2px solid var(--gray-200);
      margin-bottom: 8px;
    }

    .bar-group {
      flex: 1;
      display: flex;
      gap: 3px;
      align-items: flex-end;
      justify-content: center;
      height: 100%;
    }

    .bar {
      width: 18px;
      border-radius: 4px 4px 0 0;
      transition: height 0.3s;
      min-height: 2px;
    }

    .bar-weight { background: linear-gradient(to top, var(--primary), #60A5FA); }
    .bar-bodyfat { background: linear-gradient(to top, var(--accent), #FDBA74); }
    .bar-acute { background: linear-gradient(to top, var(--primary), #60A5FA); }
    .bar-chronic { background: linear-gradient(to top, var(--success), #6EE7B7); }

    .bar-labels {
      display: flex;
      justify-content: space-around;
      font-size: 7pt;
      color: var(--gray-400);
    }

    .chart-legend {
      display: flex;
      gap: 16px;
      justify-content: center;
      margin-top: 12px;
      font-size: 8pt;
      color: var(--gray-500);
    }

    .legend-dot {
      display: inline-block;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      margin-right: 4px;
      vertical-align: middle;
    }

    /* ACWR Indicator */
    .acwr-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
      gap: 8px;
      margin-top: 16px;
    }

    .acwr-badge {
      text-align: center;
      padding: 8px 4px;
      border-radius: 8px;
      font-size: 8pt;
    }

    .acwr-optimal { background: var(--success-light); color: #065F46; }
    .acwr-high { background: var(--danger-light); color: #991B1B; }
    .acwr-low { background: var(--warning-light); color: #92400E; }

    .acwr-value {
      font-family: var(--font-heading);
      font-size: 14pt;
      font-weight: 700;
      line-height: 1.2;
    }

    /* Goal Progress Bars */
    .goal-item {
      margin-bottom: 16px;
    }

    .goal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 6px;
    }

    .goal-name {
      font-weight: 600;
      font-size: 10pt;
      color: var(--gray-800);
      text-transform: capitalize;
    }

    .goal-percentage {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 11pt;
      color: var(--primary);
    }

    .goal-bar-bg {
      height: 10px;
      background: var(--gray-100);
      border-radius: 5px;
      overflow: hidden;
    }

    .goal-bar-fill {
      height: 100%;
      border-radius: 5px;
      background: linear-gradient(to right, var(--primary), var(--accent));
    }

    .goal-detail {
      font-size: 8pt;
      color: var(--gray-400);
      margin-top: 4px;
    }

    /* Performance Metrics */
    .perf-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .perf-card {
      background: var(--gray-50);
      border: 1px solid var(--gray-200);
      border-radius: 10px;
      padding: 14px;
    }

    .perf-type {
      font-size: 8pt;
      color: var(--gray-500);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 4px;
    }

    .perf-value {
      font-family: var(--font-heading);
      font-size: 18pt;
      font-weight: 700;
      color: var(--gray-900);
    }

    .perf-unit {
      font-size: 10pt;
      color: var(--gray-400);
      font-weight: 400;
    }

    .perf-date {
      font-size: 8pt;
      color: var(--gray-400);
      margin-top: 4px;
    }

    /* Page Footer */
    .page-footer {
      position: absolute;
      bottom: 12mm;
      left: 18mm;
      right: 18mm;
      display: flex;
      justify-content: space-between;
      font-size: 7pt;
      color: var(--gray-400);
      border-top: 1px solid var(--gray-100);
      padding-top: 8px;
    }

    @media print {
      body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .page { page-break-after: always; }
    }
  </style>
</head>
<body>

<% if (sections.includes('cover')) { %>
<!-- Cover Page -->
<div class="page cover-page">
  <div class="cover-logo">EF</div>
  <h1 class="cover-title">Progress Report</h1>
  <p class="cover-subtitle">Comprehensive Analytics Summary</p>

  <div class="cover-divider"></div>

  <div class="cover-details">
    <div class="cover-detail">
      <span class="cover-detail-label">Client</span>
      <span class="cover-detail-value"><%= clientName %></span>
    </div>
    <div class="cover-detail">
      <span class="cover-detail-label">Trainer</span>
      <span class="cover-detail-value"><%= trainerName %></span>
    </div>
    <div class="cover-detail">
      <span class="cover-detail-label">Period</span>
      <span class="cover-detail-value"><%= dateRange %></span>
    </div>
    <div class="cover-detail">
      <span class="cover-detail-label">Generated</span>
      <span class="cover-detail-value"><%= generatedAt %></span>
    </div>
  </div>

  <div class="cover-footer">
    Powered by EvoFit Trainer &bull; trainer.evofit.io
  </div>
</div>
<% } %>

<% if (sections.includes('workoutSummary')) { %>
<!-- Workout Summary -->
<div class="page">
  <div class="section-header">
    <div class="section-icon" style="background: var(--primary-light);">&#x1F4CA;</div>
    <div>
      <div class="section-title">Workout Summary</div>
      <div class="section-subtitle"><%= dateRange %></div>
    </div>
  </div>

  <div class="stat-grid">
    <div class="stat-card stat-blue">
      <div class="stat-value"><%= summary.completedWorkouts %></div>
      <div class="stat-label">Completed Workouts</div>
    </div>
    <div class="stat-card stat-green">
      <div class="stat-value"><%= summary.completionRate %>%</div>
      <div class="stat-label">Completion Rate</div>
    </div>
    <div class="stat-card stat-orange">
      <div class="stat-value"><%= summary.totalDurationMinutes > 0 ? Math.round(summary.totalDurationMinutes / 60) + 'h' : '0h' %></div>
      <div class="stat-label">Total Duration</div>
    </div>
  </div>

  <div class="stat-grid" style="grid-template-columns: repeat(2, 1fr);">
    <div class="stat-card stat-purple">
      <div class="stat-value"><%= summary.totalVolume > 0 ? Math.round(summary.totalVolume).toLocaleString() : '0' %></div>
      <div class="stat-label">Total Volume (kg)</div>
    </div>
    <div class="stat-card stat-blue">
      <div class="stat-value"><%= summary.averageRpe > 0 ? summary.averageRpe.toFixed(1) : 'N/A' %></div>
      <div class="stat-label">Average RPE</div>
    </div>
  </div>

  <div class="page-footer">
    <span>EvoFit Trainer &bull; Progress Report</span>
    <span><%= clientName %> &bull; <%= dateRange %></span>
  </div>
</div>
<% } %>

<% if (sections.includes('measurements') && measurements.length > 0) { %>
<!-- Body Measurements -->
<div class="page">
  <div class="section-header">
    <div class="section-icon" style="background: var(--success-light);">&#x1F4CF;</div>
    <div>
      <div class="section-title">Body Measurements</div>
      <div class="section-subtitle">Changes over the reporting period</div>
    </div>
  </div>

  <div class="delta-grid">
    <div class="delta-card delta-card-<%= measurementDeltas.weight.direction %>">
      <div class="delta-card-value">
        <% if (measurementDeltas.weight.delta !== 0) { %><%= measurementDeltas.weight.delta > 0 ? '+' : '' %><%= measurementDeltas.weight.delta %> kg<% } else { %>—<% } %>
      </div>
      <div class="delta-card-label">Weight</div>
    </div>
    <div class="delta-card delta-card-<%= measurementDeltas.bodyFat.direction %>">
      <div class="delta-card-value">
        <% if (measurementDeltas.bodyFat.delta !== 0) { %><%= measurementDeltas.bodyFat.delta > 0 ? '+' : '' %><%= measurementDeltas.bodyFat.delta %>%<% } else { %>—<% } %>
      </div>
      <div class="delta-card-label">Body Fat</div>
    </div>
    <div class="delta-card delta-card-<%= measurementDeltas.muscleMass.direction %>">
      <div class="delta-card-value">
        <% if (measurementDeltas.muscleMass.delta !== 0) { %><%= measurementDeltas.muscleMass.delta > 0 ? '+' : '' %><%= measurementDeltas.muscleMass.delta %> kg<% } else { %>—<% } %>
      </div>
      <div class="delta-card-label">Muscle Mass</div>
    </div>
  </div>

  <table class="measurement-table">
    <thead>
      <tr>
        <th>Date</th>
        <th>Weight (kg)</th>
        <th>Body Fat (%)</th>
        <th>Muscle Mass (kg)</th>
      </tr>
    </thead>
    <tbody>
      <% measurements.forEach(function(m) { %>
      <tr>
        <td><%= m.date %></td>
        <td><%= m.weight !== null ? m.weight : '—' %></td>
        <td><%= m.bodyFat !== null ? m.bodyFat : '—' %></td>
        <td><%= m.muscleMass !== null ? m.muscleMass : '—' %></td>
      </tr>
      <% }); %>
    </tbody>
  </table>

  <div class="page-footer">
    <span>EvoFit Trainer &bull; Progress Report</span>
    <span><%= clientName %> &bull; <%= dateRange %></span>
  </div>
</div>
<% } %>

<% if (sections.includes('bodyComposition') && bodyCompositionBars.length > 0) { %>
<!-- Body Composition Chart -->
<div class="page">
  <div class="section-header">
    <div class="section-icon" style="background: var(--accent-light);">&#x1F4C8;</div>
    <div>
      <div class="section-title">Body Composition</div>
      <div class="section-subtitle">Weight and body fat trends</div>
    </div>
  </div>

  <div class="bar-chart">
    <% bodyCompositionBars.forEach(function(bar) { %>
    <div class="bar-group">
      <div class="bar bar-weight" style="height: <%= bar.weightHeight %>%;"></div>
      <div class="bar bar-bodyfat" style="height: <%= bar.bodyFatHeight %>%;"></div>
    </div>
    <% }); %>
  </div>
  <div class="bar-labels">
    <% bodyCompositionBars.forEach(function(bar) { %>
    <span><%= bar.label %></span>
    <% }); %>
  </div>
  <div class="chart-legend">
    <span><span class="legend-dot" style="background: var(--primary);"></span> Weight</span>
    <span><span class="legend-dot" style="background: var(--accent);"></span> Body Fat %</span>
  </div>

  <div class="page-footer">
    <span>EvoFit Trainer &bull; Progress Report</span>
    <span><%= clientName %> &bull; <%= dateRange %></span>
  </div>
</div>
<% } %>

<% if (sections.includes('trainingLoad') && trainingLoadData.length > 0) { %>
<!-- Training Load -->
<div class="page">
  <div class="section-header">
    <div class="section-icon" style="background: var(--warning-light);">&#x26A1;</div>
    <div>
      <div class="section-title">Training Load</div>
      <div class="section-subtitle">Acute & chronic workload ratio (ACWR)</div>
    </div>
  </div>

  <div class="bar-chart">
    <% trainingLoadData.forEach(function(tl) { %>
    <div class="bar-group">
      <div class="bar bar-acute" style="height: <%= tl.acuteHeight %>%;"></div>
      <div class="bar bar-chronic" style="height: <%= tl.chronicHeight %>%;"></div>
    </div>
    <% }); %>
  </div>
  <div class="bar-labels">
    <% trainingLoadData.forEach(function(tl) { %>
    <span><%= tl.week %></span>
    <% }); %>
  </div>
  <div class="chart-legend">
    <span><span class="legend-dot" style="background: var(--primary);"></span> Acute Load</span>
    <span><span class="legend-dot" style="background: var(--success);"></span> Chronic Load</span>
  </div>

  <div class="acwr-grid">
    <% trainingLoadData.forEach(function(tl) { %>
    <div class="acwr-badge <%= tl.ratioValue > 1.5 ? 'acwr-high' : tl.ratioValue >= 0.8 ? 'acwr-optimal' : 'acwr-low' %>">
      <div class="acwr-value"><%= tl.ratioValue.toFixed(2) %></div>
      <div><%= tl.week %></div>
    </div>
    <% }); %>
  </div>

  <div class="page-footer">
    <span>EvoFit Trainer &bull; Progress Report</span>
    <span><%= clientName %> &bull; <%= dateRange %></span>
  </div>
</div>
<% } %>

<% if (sections.includes('goals') && goals.length > 0) { %>
<!-- Goals -->
<div class="page">
  <div class="section-header">
    <div class="section-icon" style="background: var(--primary-light);">&#x1F3AF;</div>
    <div>
      <div class="section-title">Goal Progress</div>
      <div class="section-subtitle">Active goals and completion status</div>
    </div>
  </div>

  <% goals.forEach(function(goal) { %>
  <div class="goal-item">
    <div class="goal-header">
      <div>
        <span class="goal-name"><%= goal.type.replace(/_/g, ' ') %></span>
        <% if (goal.specific) { %>
        <span style="color: var(--gray-400); font-size: 9pt;"> — <%= goal.specific %></span>
        <% } %>
      </div>
      <span class="goal-percentage"><%= goal.percentage %>%</span>
    </div>
    <div class="goal-bar-bg">
      <div class="goal-bar-fill" style="width: <%= goal.percentage %>%;"></div>
    </div>
    <div class="goal-detail">
      <% if (goal.currentValue !== null) { %>Current: <%= goal.currentValue %><% } %>
      <% if (goal.target !== null) { %> &bull; Target: <%= goal.target %><% } %>
    </div>
  </div>
  <% }); %>

  <div class="page-footer">
    <span>EvoFit Trainer &bull; Progress Report</span>
    <span><%= clientName %> &bull; <%= dateRange %></span>
  </div>
</div>
<% } %>

<% if (sections.includes('performance') && performanceMetrics.length > 0) { %>
<!-- Performance -->
<div class="page">
  <div class="section-header">
    <div class="section-icon" style="background: #EDE9FE;">&#x1F4AA;</div>
    <div>
      <div class="section-title">Performance Metrics</div>
      <div class="section-subtitle">Key performance indicators</div>
    </div>
  </div>

  <div class="perf-grid">
    <% performanceMetrics.forEach(function(m) { %>
    <div class="perf-card">
      <div class="perf-type"><%= m.type.replace(/_/g, ' ') %></div>
      <div class="perf-value"><%= m.value %> <span class="perf-unit"><%= m.unit %></span></div>
      <div class="perf-date"><%= m.date %></div>
    </div>
    <% }); %>
  </div>

  <div class="page-footer">
    <span>EvoFit Trainer &bull; Progress Report</span>
    <span><%= clientName %> &bull; <%= dateRange %></span>
  </div>
</div>
<% } %>

</body>
</html>
